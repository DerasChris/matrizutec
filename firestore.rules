rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function emailDominio() {
      return request.auth.token.email.matches('.*@gmail[.]com$');
    }

    function getRol(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.rol;
    }

    function rolUsuario() {
      return getRol(request.auth.uid);
    }

    function esEncargado() {
      return isAuth() && rolUsuario() == 'encargado';
    }

    function esJefa() {
      return isAuth() && rolUsuario() == 'jefa';
    }

    function esAdmin() {
      return esEncargado() || esJefa();
    }

    function usuarioActivo() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo == true;
    }

    // Valida que una creación es una solicitud pública legítima (sin auth)
    function esSolicitudPublica() {
      return request.resource.data.esExterno == true
          && request.resource.data.docenteId == 'publico'
          && request.resource.data.estado == 'pendiente';
    }

    match /usuarios/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || esAdmin());
      allow create: if isAuth()
                    && request.auth.uid == userId
                    && emailDominio()
                    && request.resource.data.rol == 'docente'
                    && request.resource.data.activo == true;
      allow update: if isAuth() && (
        (request.auth.uid == userId
          && request.resource.data.rol == resource.data.rol
          && request.resource.data.activo == resource.data.activo)
        || esJefa()
      );
      allow delete: if esJefa();
    }

    match /laboratorios/{labId} {
      // Lectura pública: el formulario externo necesita cargar los labs disponibles
      allow read: if true;
      allow write: if esAdmin() && usuarioActivo();
    }

    match /ciclos/{cicloId} {
      // Lectura pública: necesario para obtener el ciclo activo y verificar disponibilidad
      allow read: if true;
      allow write: if esAdmin() && usuarioActivo();
    }

    match /clasesRegulares/{claseId} {
      // Lectura pública: necesario para mostrar disponibilidad en el formulario externo
      allow read: if true;
      allow create, update, delete: if esAdmin() && usuarioActivo();
    }

    match /reservas/{reservaId} {
      // Lectura: admins ven todo, docentes ven las suyas, público puede leer para verificar disponibilidad
      allow read: if (isAuth() && (esAdmin() || resource.data.docenteId == request.auth.uid))
                  || true;

      allow create: if
        // Usuario interno autenticado y activo creando su propia reserva
        (isAuth() && usuarioActivo() && request.resource.data.docenteId == request.auth.uid && request.resource.data.estado == 'pendiente')
        ||
        // Solicitud pública — permitida con o sin sesión abierta
        esSolicitudPublica();

      allow update: if isAuth() && (
        (esJefa() && usuarioActivo())
        ||
        (resource.data.docenteId == request.auth.uid
         && resource.data.estado == 'pendiente'
         && request.resource.data.estado == 'cancelada')
      );

      allow delete: if esJefa();
    }

    match /notificaciones/{notifId} {
      allow read: if isAuth() && resource.data.destinatarioId == request.auth.uid;
      allow create: if esAdmin();
      allow update: if isAuth() && resource.data.destinatarioId == request.auth.uid;
      allow delete: if isAuth() && resource.data.destinatarioId == request.auth.uid;
    }

    // Cola de emails: escritura pública para poder encolar notificaciones de solicitudes externas
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if esAdmin();
    }

    match /configuracion/{docId} {
      allow read: if isAuth();
      allow write: if esJefa();
    }
  }
}
